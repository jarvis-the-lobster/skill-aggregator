# Server Configuration
PORT=3001
NODE_ENV=development

# Database
DB_PATH=./database/skills.db

# API Keys
# YouTube Data API v3 key — get one at https://console.cloud.google.com/
# Enable "YouTube Data API v3" in your project. Without this, YouTube scraping is skipped.
YOUTUBE_API_KEY=your_youtube_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Scraping Configuration
SCRAPE_DELAY_MS=1000      # ms to wait between scraping each skill
MAX_RESULTS_PER_SOURCE=30 # max items to fetch per source per skill

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173